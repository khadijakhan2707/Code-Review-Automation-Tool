#!/bin/sh
#
# Pre-commit hook for Code Review Automation Tool
# This hook is triggered before each commit and runs automated code review
#
# Installation:
#   ./setup.py install
#
# Or manually:
#   cp hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo ""
echo "========================================================================"
echo "Running Code Review Automation Tool..."
echo "========================================================================"
echo ""

# Get the root directory of the git repository
REPO_ROOT=$(git rev-parse --show-toplevel)

# Change to repository root
cd "$REPO_ROOT" || exit 1

# Check if Python is available
if ! command -v python3 &> /dev/null && ! command -v python &> /dev/null; then
    echo "${RED}❌ Error: Python not found${NC}"
    echo "Please install Python 3.8 or higher"
    exit 1
fi

# Use python3 if available, otherwise use python
if command -v python3 &> /dev/null; then
    PYTHON_CMD="python3"
else
    PYTHON_CMD="python"
fi

# Check if main.py exists
if [ ! -f "main.py" ]; then
    echo "${RED}❌ Error: main.py not found${NC}"
    echo "Please ensure you're in the Code Review Automation Tool directory"
    exit 1
fi

# Check if dependencies are installed
$PYTHON_CMD -c "import flake8, bandit, radon" 2>/dev/null
if [ $? -ne 0 ]; then
    echo "${YELLOW}⚠️  Warning: Required dependencies not found${NC}"
    echo "Installing dependencies..."
    $PYTHON_CMD -m pip install -q flake8 bandit radon
fi

# Run the code review tool on staged files
$PYTHON_CMD main.py --staged

# Capture exit code
EXIT_CODE=$?

# If review failed, prevent commit
if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "${RED}======================================================================${NC}"
    echo "${RED}❌ COMMIT BLOCKED - Code review failed${NC}"
    echo "${RED}======================================================================${NC}"
    echo ""
    echo "Please fix the issues above and try committing again."
    echo ""
    echo "To bypass this check (not recommended):"
    echo "  git commit --no-verify"
    echo ""
    exit 1
fi

echo "${GREEN}✅ Code review passed - proceeding with commit${NC}"
echo ""
exit 0
